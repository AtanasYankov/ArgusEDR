<UserControl x:Class="Argus.GUI.Views.PrivacyGuardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel>
                <TextBlock Text="Privacy Guard" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Windows privacy hardening - 26 toggles" FontSize="13"
                           Foreground="{StaticResource TextMuted}" Margin="0 4 0 0"/>
                <Border Height="1" Background="{StaticResource BorderDefault}" Margin="0 16"/>
            </StackPanel>

            <!-- Top bar: Enable All / Disable All + changes indicator → Apply -->
            <Grid Grid.Row="1" Margin="0 0 0 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="Enable All" Style="{StaticResource SmallButton}" Margin="0 0 4 0"/>
                    <Button Content="Disable All" Style="{StaticResource SmallButton}" Margin="4 0 0 0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Apply Privacy Settings"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplySelectedCommand}"/>
            </Grid>

            <!-- Status message -->
            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{StaticResource TextSecondary}" Margin="0 0 0 8"/>

            <!-- Category sections -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding GroupedToggles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0 0 0 16">
                            <TextBlock Text="{Binding Key}" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="0 0 0 8"/>
                            <Border Height="1" Background="{StaticResource BorderDefault}" Margin="0 0 0 8"/>

                            <ItemsControl ItemsSource="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0 0 0 8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Toggle name (with WhatBreaks as tooltip) -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}" Margin="0 2 0 0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <!-- Toggle switch -->
                                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding Enabled}" Margin="0 2 0 0"
                                                      ToolTip="{Binding WhatBreaks}"
                                                      HorizontalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer -->
            <Border Grid.Row="4" BorderBrush="{StaticResource BorderDefault}" BorderThickness="0 1 0 0"
                    Padding="0 12" Margin="0 16 0 0">
                <Button Content="Apply Changes" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplySelectedCommand}"
                        HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
