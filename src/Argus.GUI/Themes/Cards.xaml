<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ArgusTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ============================================================ -->
    <!-- Stat Card (dashboard stat blocks)                                  -->
    <!-- ============================================================ -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <!-- ============================================================ -->
    <!-- Content Card (general purpose panel)                              -->
    <!-- ============================================================ -->
    <Style x:Key="ContentCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="24"/>
    </Style>

    <!-- ============================================================ -->
    <!-- Status Badge (pill - 8px radius)                                    -->
    <!-- ============================================================ -->
    <ControlTemplate x:Key="BadgeGreen" TargetType="Border">
        <Border Background="{StaticResource BgBadgeGreen}" CornerRadius="12" Padding="8 4">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource StatusGreen}"
                         VerticalAlignment="Center" Margin="0 0 6 0"/>
                <ContentPresenter TextElement.Foreground="{StaticResource TextBadgeGreen}"
                                  VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="BadgeGold" TargetType="Border">
        <Border Background="{StaticResource BgBadgeGold}" CornerRadius="12" Padding="8 4">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource TextBadgeGold}"
                         VerticalAlignment="Center" Margin="0 0 6 0"/>
                <ContentPresenter TextElement.Foreground="{StaticResource TextBadgeGold}"
                                  VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="BadgeRed" TargetType="Border">
        <Border Background="{StaticResource BgBadgeRed}" CornerRadius="12" Padding="8 4">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource TextBadgeRed}"
                         VerticalAlignment="Center" Margin="0 0 6 0"/>
                <ContentPresenter TextElement.Foreground="{StaticResource TextBadgeRed}"
                                  VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="BadgeGray" TargetType="Border">
        <Border Background="{StaticResource BgBadgeGray}" CornerRadius="12" Padding="8 4">
            <ContentPresenter TextElement.Foreground="{StaticResource TextBadgeGray}"
                              VerticalAlignment="Center"/>
        </Border>
    </ControlTemplate>

    <!-- ============================================================ -->
    <!-- Category Header (section divider)                                  -->
    <!-- ============================================================ -->
    <Style x:Key="CategoryHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>

</ResourceDictionary>
